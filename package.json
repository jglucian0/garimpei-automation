{
  "name": "garimpei-automation",
  "version": "1.0.0",
  "description": "Serviço de automação e orquestração de mensagens. Responsável pela ingestão de produtos de múltiplas fontes, processamento de dados e distribuição programada em canais, garantindo consistência, escalabilidade e eficiência operacional.",
  "main": "index.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "services:up": "docker compose up -d",
    "services:build": "docker compose up --build",
    "services:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "lint:prettier:check": "prettier --check .",
    "lint:prettier:fix": "prettier --write .",
    "lint:eslint:check": "eslint .",
    "lint:eslint:fix": "eslint . --fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jglucian0/garimpei-api-rest.git"
  },
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jglucian0/garimpei-api-rest/issues"
  },
  "homepage": "https://github.com/jglucian0/garimpei-api-rest#readme",
  "dependencies": {
    "axios": "^1.13.6",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "pg": "^8.20.0",
    "puppeteer": "^24.39.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-no-secrets": "^2.3.3",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2"
  }
}